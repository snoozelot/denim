#!/usr/bin/env -S bash -euo pipefail
# spell-number — spell numbers as words in four languages
#
# WHAT IT DOES
#
# Converts numbers (including decimals) to pronounceable text in DE, EN, FR,
# and RU. Handles locale-specific separators automatically:
#
#   DE/FR/RU: 1.234,56  → drei-hundert-vier-und-zwanzig Millionen ... Komma fünf sechs
#   EN:       1,234.56  → one-million two-hundred-thirty-four-thousand ... point five six
#
# Output format: hyphens within each 3-digit-block+scale unit, spaces between
# units and around the decimal word.
#
# Supports 0 to 10^66-1 (DE/FR), 10^63-1 (EN), 10^33-1 (RU).
#
# USAGE
#
#   spell-number [-l de|en|fr|ru] [NUMBER]
#
# Reads NUMBER from stdin if not given. Default language: de.
#
# EXAMPLES
#
#   spell-number 42                            # zwei-und-vierzig
#   spell-number -l en 42                      # forty-two
#   spell-number -l fr 71                      # soixante-et-onze
#   spell-number -l ru 1000                    # одна-тысяча
#   spell-number -l de 1.040,43                # ein-tausend vierzig Komma vier drei
#   spell-number -l en 1,040.43                # one-thousand forty point four three
#   echo "3,14" | spell-number -l fr           # trois virgule un quatre
#   echo "-5"   | spell-number -l en           # negative five
#
# EXIT CODES
#
#   0   Success
#   1   Invalid input

# ── Helpers ──

die()          { echo "$1" >&2; exit 1; }
got()          { [[ -n $1 ]]; }
no()           { [[ -z $1 ]]; }

usage() {
    sed -n '/^# WHAT IT DOES/,/^# EXIT CODES/p' "$0" | sed 's/^# *//'
}

# ── Predicates ──

is_negative()         { [[ $1 == -* ]]; }
is_valid_integer()    { [[ $1 =~ ^[0-9]+$ ]]; }
is_zero()             { [[ $1 == 0 ]]; }
is_unit_part()        { [[ $1 -eq 1 ]]; }
is_feminine_scale()   { [[ $1 -eq 1 ]]; }
has_decimal_comma()   { [[ $1 == *,* ]]; }
has_decimal_point()   { [[ $1 == *.* ]]; }
is_grouping_dot()     { [[ ${#1} -eq 3 && $2 == *.??? ]]; }
is_seventies()        { [[ $1 -ge 70 && $1 -lt 80 ]]; }
is_eighty()           { [[ $1 -eq 80 ]]; }
is_teen_range()       { [[ $1 -ge 11 && $1 -le 19 ]]; }
is_two_to_four()      { [[ $1 -ge 2 && $1 -le 4 ]]; }
hundreds_are_plural() { [[ $1 -gt 1 && $2 -eq 0 ]]; }

# ── Language lookups ──

neg_prefix() {
    case $1 in
        de) echo "minus"    ;;
        en) echo "negative" ;;
        fr) echo "moins"    ;;
        ru) echo "минус"    ;;
    esac
}

decimal_word() {
    case $1 in
        de) echo "Komma"    ;;
        en) echo "point"    ;;
        fr) echo "virgule"  ;;
        ru) echo "запятая"  ;;
    esac
}

