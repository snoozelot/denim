# ── Chunk iteration (shared by all languages) ──
# Decompose N into 3-digit groups and spell each via language chunk function

spell_chunk() {
    local LANG=$1
    local PART=$2
    local SCALE=$3
    local IS_LAST=$4

    case $LANG in
        de) spell_de_chunk "$PART" "$SCALE" "$IS_LAST" ;;
        en) spell_en_chunk "$PART" "$SCALE" ;;
        fr) spell_fr_chunk "$PART" "$SCALE" ;;
        ru) spell_ru_chunk "$PART" "$SCALE" ;;
    esac
}

process_chunks() {
    # Builds output right-to-left (least significant chunk first), using `|`
    # as an internal separator.  Each spell_XX_chunk call returns one chunk's
    # words; the caller's sed pipeline replaces `|` with spaces.
    local LANG=$1 N=$2 OUT="" SCALE=0 PART

    while [[ -n $N ]]; do
        if [[ ${#N} -gt 3 ]]; then
            PART=$((10#${N: -3}))
            N=${N:0:${#N}-3}
        else
            PART=$((10#$N))
            N=""
        fi
        if (( PART > 0 )); then
            local IS_LAST=0 CHUNK
            [[ -z $N ]] && IS_LAST=1
            CHUNK=$(spell_chunk "$LANG" "$PART" "$SCALE" "$IS_LAST")
            CHUNK=${CHUNK% }
            OUT="$CHUNK|"$OUT
        fi
        ((SCALE++))
    done
    echo "${OUT% }"
}

# ── EN: integer spelling ──

spell_en_chunk() {
    local PART=$1
    local SCALE=$2
    local BLOCK=""
    local H=$(( PART / 100 ))
    local R=$(( PART % 100 ))

    if (( H > 0 )); then
        BLOCK+="${EN_ONES[$H]} hundred "
    fi
    if (( R > 0 )); then
        if (( R < 20 )); then
            BLOCK+="${EN_ONES[$R]} "
        else
            local T=$(( R / 10 ))
            local O=$(( R % 10 ))
            BLOCK+="${EN_TENS[$T]}"
            if (( O > 0 )); then BLOCK+="-${EN_ONES[$O]}"; fi
            BLOCK+=" "
        fi
    fi
    if (( SCALE > 0 )); then
        BLOCK+="${EN_SCALES[$SCALE]} "
    fi
    echo "$BLOCK"
}

spell_en() {
    local N=$1

    if is_zero "$N"; then echo "zero"; return 0; fi
    process_chunks en "$N" | sed 's/  */-/g; s/|/ /g; s/ *$//'
}

# ── DE: integer spelling ──
# German has special overwrite rules for "eins" vs "ein" and scale agreement:
#   - Number 1 alone → "eins", in compound → "ein"
#   - Scale 1, part 1 → "ein tausend" (overwrites body)
#   - Scale 2+, part 1 → "eine Million/Milliarde…" (overwrites body)

de_tens_ones() {
    local R=$1

    if (( R < 20 )); then
        echo "${DE_ONES[$R]}"
        return 0
    fi

    local T=$(( R / 10 ))
    local O=$(( R % 10 ))
    local UW=${DE_ONES[$O]}
    if [[ $O -eq 1 ]]; then UW="ein"; fi

    if (( O == 0 )); then echo "${DE_TENS[$T]}"; return; fi
    echo "${UW}-und-${DE_TENS[$T]}"
}

spell_de_chunk() {
    local PART=$1
    local SCALE=$2
    local IS_LAST=$3

    # Scale 1, part 1: "ein tausend" (body overwritten)
    if is_unit_part "$PART" && [[ $SCALE -eq 1 ]]; then
        echo "ein tausend "
        return 0
    fi

    # Scale 2+, part 1: "eine Million/Milliarde…" (body overwritten)
    if is_unit_part "$PART" && (( SCALE > 1 )); then
        echo "eine ${DE_SCALES[$SCALE]} "
        return 0
    fi

    # Scale 0, part 1, last: "eins" (body overwritten)
    if is_unit_part "$PART" && is_zero "$SCALE" && [[ $IS_LAST -eq 1 ]]; then
        echo "eins"
        return 0
    fi

    # Normal path: hundreds + tens/ones + scale suffix
    local BLOCK=""
    local H=$(( PART / 100 ))
    local R=$(( PART % 100 ))

    if (( H > 0 )); then
        if (( H == 1 )); then BLOCK+="ein hundert"
        else BLOCK+="${DE_ONES[$H]} hundert"
        fi
    fi
    if (( R > 0 )); then
        if [[ -n $BLOCK ]]; then BLOCK+=" "; fi
        BLOCK+=$(de_tens_ones "$R")
    fi
    if (( SCALE == 1 )); then
        BLOCK+=" tausend "
    elif (( SCALE > 1 )); then
        BLOCK+=" ${DE_SCALES_PL[$SCALE]} "
    fi
    echo "$BLOCK"
}

spell_de() {
    local N=$1

    if is_zero "$N"; then echo "null"; return 0; fi
    process_chunks de "$N" | sed 's/  */-/g; s/|/ /g; s/ *$//'
}

# ── FR: integer spelling ──
# French 70-79: soixante-dix, 80: quatre-vingts, 81-89: quatre-vingt-X,
# 90-99: quatre-vingt-dix

fr_tens_ones() {
    local R=$1

    if is_seventies "$R"; then
        local SUB=$(( R - 60 ))
        if (( SUB == 11 )); then echo "soixante et onze"; return 0; fi
        echo "soixante-${FR_ONES[$SUB]}"
        return 0
    fi

    if (( R >= 81 )); then
        local SUB=$(( R - 80 ))
        if (( SUB == 1 )); then echo "quatre-vingt-un"; return 0; fi
        echo "quatre-vingt-${FR_ONES[$SUB]}"
        return 0
    fi

    if is_eighty "$R"; then echo "quatre-vingts"; return 0; fi

    if (( R < 20 )); then echo "${FR_ONES[$R]}"; return; fi

    # 20-69
    local T=$(( R / 10 ))
    local O=$(( R % 10 ))
    local OUT=${FR_TENS[$T]}
    if (( O == 1 )); then
        OUT+=" et un"
    elif (( O > 0 )); then
        OUT+="-${FR_ONES[$O]}"
    fi
    echo "$OUT"
}

spell_fr_chunk() {
    local PART=$1
    local SCALE=$2
    local BLOCK=""
    local H=$(( PART / 100 ))
    local R=$(( PART % 100 ))

    if (( H > 0 )); then
        if (( H == 1 )); then BLOCK+="cent "
        else BLOCK+="${FR_ONES[$H]} cent "
        fi
        if [[ $SCALE -eq 0 ]] && hundreds_are_plural "$H" "$R"; then
            BLOCK="${BLOCK%cent }cents "
        fi
    fi
    if (( R > 0 )); then
        local TENS_RESULT
        TENS_RESULT=$(fr_tens_ones "$R")
        if (( SCALE > 0 )) && [[ $TENS_RESULT == "quatre-vingts" ]]; then
            TENS_RESULT="quatre-vingt"
        fi
        BLOCK+="$TENS_RESULT "
    fi
    if (( SCALE == 1 )); then
        BLOCK+="mille "
    elif (( SCALE > 1 && PART == 1 )); then
        BLOCK+="${FR_SCALES[$SCALE]} "
    elif (( SCALE > 1 )); then
        BLOCK+="${FR_SCALES_PL[$SCALE]} "
    fi
    echo "$BLOCK"
}

spell_fr() {
    local N=$1

    if is_zero "$N"; then echo "zéro"; return 0; fi
    process_chunks fr "$N" | sed 's/  */-/g; s/|/ /g; s/ *$//'
}

# ── RU: integer spelling ──
# Scales have grammatical agreement: тысяча, тысячи, тысяч
# Gender forms: одна/один for feminine/masculine units

ru_scale_agreement() {
    local PART=$1
    local SCALE=$2
    local P10=$(( PART % 10 ))
    local P100=$(( PART % 100 ))

    if is_teen_range "$P100"; then
        echo "${RU_SCALES_PLURAL[$SCALE]} "
    elif (( P10 == 1 )); then
        echo "${RU_SCALES[$SCALE]} "
    elif is_two_to_four "$P10"; then
        echo "${RU_SCALES_TWO[$SCALE]} "
    else
        echo "${RU_SCALES_PLURAL[$SCALE]} "
    fi
}

ru_ones_gender() {
    local DIGIT=$1
    local SCALE=$2

    if is_feminine_scale "$SCALE"; then
        echo "${RU_ONES_F[$DIGIT]} "
    else
        echo "${RU_ONES_M[$DIGIT]} "
    fi
}

spell_ru_chunk() {
    local PART=$1
    local SCALE=$2
    local BLOCK=""
    local H=$(( PART / 100 ))
    local R=$(( PART % 100 ))

    if (( H > 0 )); then BLOCK+="${RU_HUNDREDS[$H]} "; fi

    if (( R >= 20 )); then
        local T=$(( R / 10 ))
        local O=$(( R % 10 ))
        BLOCK+="${RU_TENS[$T]} "
        if (( O > 0 )); then
            BLOCK+=$(ru_ones_gender "$O" "$SCALE")
        fi
    elif (( R >= 10 )); then
        BLOCK+="${RU_TEENS[$(( R - 10 ))]} "
    elif (( R > 0 )); then
        BLOCK+=$(ru_ones_gender "$R" "$SCALE")
    fi

    if (( SCALE > 0 )); then
        BLOCK+=$(ru_scale_agreement "$PART" "$SCALE")
    fi
    echo "$BLOCK"
}

spell_ru() {
    local N=$1

    if is_zero "$N"; then echo "ноль"; return 0; fi
    process_chunks ru "$N" | sed 's/  */-/g; s/|/ /g; s/ *$//'
}

# ── Number parsing ──
# DE/FR/RU: decimal comma, grouping dot
# EN:       decimal point, grouping comma
# Output: "INT|FRAC" — FRAC empty when no fractional part

parse_european() {
    local NUM=$1
    local INT
    local FRAC
    local AFTER_DOT

    if has_decimal_comma "$NUM"; then
        INT=${NUM%%,*}
        FRAC=${NUM#*,}
    elif has_decimal_point "$NUM"; then
        AFTER_DOT=${NUM#*.}
        if is_grouping_dot "$AFTER_DOT" "$NUM"; then
            NUM="${NUM%.*}$AFTER_DOT"
        fi
        INT=${NUM%.*}
        FRAC=${NUM#*.}
        # FRAC == INT means no separator was found — restore to empty
        if [[ $FRAC == "$INT" ]]; then FRAC=""; fi
    else
        INT=$NUM
        FRAC=""
    fi
    INT=${INT//./}
    echo "$INT|$FRAC"
}

parse_english() {
    local NUM=$1
    local INT
    local FRAC
    NUM=$(echo "$NUM" | sed 's/,\([0-9][0-9][0-9]\)/\1/g')
    INT=${NUM%%.*}
    FRAC=${NUM#*.}
    if [[ $FRAC == "$INT" ]]; then FRAC=""; fi
    echo "$INT|$FRAC"
}

# ── Fraction spelling ──

spell_fraction() {
    local LANG=$1
    local FRAC=$2
    local WORDS=""
    local D
    local W
    local -n DIGITS=DIGIT_${LANG^^}

    for (( I=0; I<${#FRAC}; I++ )); do
        D=${FRAC:$I:1}
        W=${DIGITS[$D]}
        WORDS+="$W "
    done
    echo "${WORDS% }"
}

# ── Orchestration ──

LANG=de
ARGS=()

parse_flags() {
    LANG=de
    ARGS=()

    while [[ $# -gt 0 ]]; do
        case $1 in
            -l)
                shift
                case ${1:-} in
                    de|en|fr|ru) LANG=$1 ;;
                    *) die "spell-number: invalid language '$1' (use de|en|fr|ru)" ;;
                esac
                ;;
            -l*) LANG=${1#-l} ;;
            -h|--help) usage; exit 0 ;;
            *) ARGS+=("$1") ;;
        esac
        shift
    done
}

read_input() {
    local NUM

    if (( ${#ARGS[@]} > 0 )); then
        NUM=${ARGS[0]}
    else
        read -r NUM || die "no input"
    fi
    NUM=${NUM//[[:space:]]/}
    got "$NUM" || die "empty input"
    echo "$NUM"
}

strip_sign() {
    local NUM=$1

    if is_negative "$NUM"; then
        echo "1|${NUM#-}"
    else
        echo "|${NUM}"
    fi
}

split_number() {
    local LANG=$1
    local NUM=$2

    case $LANG in
        de|fr|ru) parse_european "$NUM" ;;
        en)       parse_english "$NUM" ;;
    esac
}

normalize_integer() {
    local VALUE=$1

    is_valid_integer "$VALUE" || die "invalid number"
    VALUE=${VALUE#0}
    while [[ $VALUE == 0* ]]; do VALUE=${VALUE#0}; done
    VALUE=${VALUE:-0}
    echo "$VALUE"
}

spell_integer() {
    local LANG=$1
    local VALUE=$2

    case $LANG in
        de) spell_de "$VALUE" ;;
        en) spell_en "$VALUE" ;;
        fr) spell_fr "$VALUE" ;;
        ru) spell_ru "$VALUE" ;;
    esac
}

apply_neg_prefix() {
    local SIGN=$1
    local LANG=$2
    local WORD=$3
    local PREFIX

    if got "$SIGN"; then
        PREFIX=$(neg_prefix "$LANG")
        echo "$PREFIX $WORD"
    else
        echo "$WORD"
    fi
}

emit_result() {
    local LANG=$1
    local INT_WORD=$2
    local FRAC=$3
    local DEC_WORD
    local FRAC_SPELLED

    if no "$FRAC"; then
        echo "$INT_WORD"
        return 0
    fi
    is_valid_integer "$FRAC" || die "invalid decimal"
    DEC_WORD=$(decimal_word "$LANG")
    FRAC_SPELLED=$(spell_fraction "$LANG" "$FRAC")
    echo "$INT_WORD $DEC_WORD $FRAC_SPELLED"
}

main() {
    local NUM
    local NEG=""
    local STRIPPED
    local PARSED
    local INT
    local FRAC
    local INT_WORD

    parse_flags "$@"
    NUM=$(read_input)
    STRIPPED=$(strip_sign "$NUM")
    NEG=${STRIPPED%|*}
    NUM=${STRIPPED#*|}
    PARSED=$(split_number "$LANG" "$NUM")
    INT=${PARSED%|*}
    FRAC=${PARSED#*|}
    INT=$(normalize_integer "$INT")
    INT_WORD=$(spell_integer "$LANG" "$INT")
    INT_WORD=$(apply_neg_prefix "$NEG" "$LANG" "$INT_WORD")
    emit_result "$LANG" "$INT_WORD" "$FRAC"
}

main "$@"
