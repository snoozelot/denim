#!/usr/bin/env bash
# cpstamped — timestamped backups before editing
#
# WHAT IT DOES
#
# Create a timestamped copy before editing.  One command per file, one
# backup per edit.  Handles files and directories, with three link
# modes for symbolic links (keep, shallow, deep).
#
# WHY
#
# Quick timestamped backups before editing.  Avoids the "wish you'd
# backed it up first" cycle.  One command, no thinking.
#
# HOW IT WORKS
#
# Appends epoch seconds to the path (config → config.1735689600).
# Files: cp with link-mode flags.  Directories: tar piped to tar
# extract (single pass, excludes .terraform and sessions).  List mode
# globs existing backups and shows them with human timestamps.
#
# USAGE
#
#   cpstamped [-l|-n] [--link-mode keep|shallow|deep] [--limbo|--target-dir DIR] PATH...
#
# OPTIONS
#
#   -l                   List existing backups with human-readable timestamps
#   -n                   Dry run — show what would be copied without copying
#   --link-mode MODE     Link resolution: keep|shallow (default)|deep
#   --limbo              Create backup in ~/.limbo/YYYY-MM-DD/ instead of alongside
#   --target-dir DIR     Create backup in DIR/ instead of alongside
#   -h, --help           Show this help
#
# EXAMPLES
#
#   cpstamped config.yaml                   # creates config.yaml.1712345678 (shallow)
#   cpstamped --link-mode keep config.yaml  # preserve symlinks as symlinks
#   cpstamped --link-mode deep /etc/nginx/  # materialize everything recursively
#   cpstamped -l config.yaml                # list all backups of config.yaml
#   cpstamped -n /etc/nginx/                # dry-run backup of directory
#   cpstamped --limbo file.c                # backup to ~/.limbo/YYYY-MM-DD/
#   cpstamped --target-dir /tmp/backups f   # backup to /tmp/backups/
#
# CP FLAGS
#
#   -P    Never follow symlinks — copy the link itself
#   -p    Preserve mode, ownership, timestamps
#   -R    Recursive copy (directories)
#   -L    Follow symlinks — materialize target (deep mode)
#
# Flag combos by mode:
#   keep symlink         cp -Pp      — copies the symlink as-is
#   shallow (file)       cp -Pp      — copies the resolved file
#   shallow (directory)  tar         — cp -Rp semantically
#   deep (file)          cp -RpL     — follow and materialize recursively
#   deep (directory)     tar --dereference — cp -RpL semantically
#
# EXIT CODES
#
#   0   All backups created successfully
#   1   One or more paths failed (missing, broken symlink, write error)
#
# DEPENDENCIES
#
#   coreutils: realpath, stat, column, sort, cut
#   util-linux: date (with -d @epoch support)
#   POSIX: cp (with -P, -R, -p, -L), tar, readlink

set -euo pipefail

readonly TIMESTAMP_GLOB='.[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]'
readonly LIMBO_DIR=~/.limbo
readonly -a EXCLUDE=(.terraform sessions)

# ============================================================================
# Predicates
# ============================================================================

has_arguments()  { [[ $# -gt 0 ]]; }
is_dryrun()      { [[ -n "${DRYRUN:-}" ]]; }
exists()         { [[ -e $1 ]]; }
is_directory()   { [[ -d $1 ]]; }
is_symlink()     { [[ -L $1 ]]; }
has_timestamp()  { [[ $1 =~ \.([0-9]{10})$ ]]; }  # SIDEFF: sets BASH_REMATCH
got()            { [[ -n $1 ]]; }
no()             { [[ -z $1 ]]; }

# ============================================================================
# Helpers
# ============================================================================

usage()            { sed -n '2,/^$/{ s/^# \?//p }' "$0"; }
file_mtime()       { stat -c %Y "$1" 2>/dev/null || echo 0; }
format_timestamp() { date -d "@$1" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "invalid"; }
die()              { echo "$*" >&2; exit 1; }
log() { local LEVEL=$1; shift; printf >&2 "[%s]" "$LEVEL"; printf >&2 ' %q' "$@"; printf >&2 '\n'; }
run() { log INFO "$@"; "$@"; }

# ============================================================================
# List mode
# ============================================================================

print_backup_info() {
    local BACKUP=$1
    local STAMP
    local FORMATTED
    if has_timestamp "$BACKUP"; then
        STAMP=${BASH_REMATCH[1]}
    else
        STAMP=$(file_mtime "$BACKUP")
    fi
    FORMATTED=$(format_timestamp "$STAMP")
    printf '%s\t%s\t%s\n' "$STAMP" "$BACKUP" "$FORMATTED"
}

list_backups() {
    local ARG
    local SRC
    local BACKUP

    for ARG; do
        SRC=$(realpath -s -- "$ARG")
        print_backup_info "$SRC"
        for BACKUP in "$SRC"$TIMESTAMP_GLOB; do
            exists "$BACKUP" || continue
            print_backup_info "$BACKUP"
        done
    done | sort -n | cut -f2- | column -t -s $'\t'
}

# ============================================================================
# Copy mode
# ============================================================================

# Copy with link-mode control, excluding defined patterns via tar
create_snapshot() {
    local SRC=$1
    local SNAPSHOT=$2
    local LINK_MODE=$3
    local REAL
    local DEEP_FLAG

    if is_dryrun; then
        log DRY cp "$SRC" "$SNAPSHOT"
        return 0
    fi

    # keep: symlinks stay as symlinks
    if [[ $LINK_MODE == keep ]] && is_symlink "$SRC"; then
        run cp -Pp "$SRC" "$SNAPSHOT"
        return 0
    fi

    # shallow: resolve top-level argument
    if [[ $LINK_MODE == shallow ]]; then
        REAL=$(realpath -- "$SRC") || { echo "cpstamped: $SRC: broken symlink" >&2; return 1; }
    else
        REAL=$SRC
    fi

    if is_directory "$REAL"; then
        log INFO cp -Rp "$REAL" "$SNAPSHOT"
        DEEP_FLAG=()
        mkdir -p "$SNAPSHOT"
        if [[ $LINK_MODE == deep ]]; then DEEP_FLAG=(--dereference); fi
        tar cf - "${EXCLUDE[@]/#/--exclude=}" "${DEEP_FLAG[@]}" -C "$REAL" . \
        | tar xf - -C "$SNAPSHOT" \
        || return 1
    elif [[ $LINK_MODE == deep ]]; then
        run cp -RpL "$REAL" "$SNAPSHOT"
    else
        run cp -Pp "$REAL" "$SNAPSHOT"
    fi
}

# ============================================================================
# Main
# ============================================================================

# Returns 0 and prints dry-run skip message when snapshot already exists
skip_existing_snapshot() {
    local SNAPSHOT=$1

    if exists "$SNAPSHOT"; then
        if is_dryrun; then echo "[DRY] snapshot exists, would be skipped: $SNAPSHOT" >&2; fi
        return 0
    fi
    return 1
}

main() {
    local ARG
    local SRC
    local SNAPSHOT
    local STAMP
    local LINK_MODE=shallow
    local TARGET_DIR=
    local LIST=
    local DRYRUN=
    local RC=0

    parse_options "$@"

    has_arguments "${REMAINING[@]}" || { usage; exit 0; }

    if got "$LIST"; then list_backups "${REMAINING[@]}"; exit 0; fi

    STAMP=$(TZ=UTC date '+%s')

    for ARG in "${REMAINING[@]}"; do
        SRC=$(realpath -s -- "$ARG")
        exists "$SRC" || { echo "cpstamped: $ARG: No such file or directory" >&2; RC=1; continue; }
        if got "$TARGET_DIR"; then
            is_dryrun || mkdir -p "$TARGET_DIR"
            BASENAME=$(basename "$SRC")
            SNAPSHOT="${TARGET_DIR}/${BASENAME}.${STAMP}"
        else
            SNAPSHOT="${SRC}.${STAMP}"
        fi
        if skip_existing_snapshot "$SNAPSHOT"; then continue; fi
        create_snapshot "$SRC" "$SNAPSHOT" "$LINK_MODE" || RC=$?
        if ! is_dryrun && [[ $RC -eq 0 ]] && got "$TARGET_DIR"; then echo "$SNAPSHOT"; fi
    done

    exit $RC
}

# ============================================================================
# Option parsing — sets LINK_MODE, LIST, DRYRUN, REMAINING
# ============================================================================

REMAINING=()

# SIDEFF: sets LIST, DRYRUN from bundled flags
parse_bundled_flags() {
    local FLAGS=$1
    while got "$FLAGS"; do
        case ${FLAGS:0:1} in
            l) LIST=1 ;;
            n) DRYRUN=1 ;;
            *) die "cpstamped: unknown flag -${FLAGS:0:1}" ;;
        esac
        FLAGS=${FLAGS:1}
    done
}

parse_options() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)  usage; exit 0 ;;
            -l)         LIST=1; shift ;;
            -n)         DRYRUN=1; shift ;;
            --limbo)    TARGET_DIR="$LIMBO_DIR/$(date +%F)"; shift ;;
            --target-dir)
                shift
                got "${1:-}" || die "cpstamped: --target-dir requires a directory"
                TARGET_DIR=$1; shift
                ;;
            --link-mode)
                shift
                case ${1:-} in
                    keep|shallow|deep) LINK_MODE=$1; shift ;;
                    *) die "cpstamped: --link-mode requires keep|shallow|deep" ;;
                esac
                ;;
            --)         shift; break ;;
            -?*)
                parse_bundled_flags "${1:1}"
                shift
                ;;
            *) break ;;
        esac
    done
    REMAINING=("$@")
}

main "$@"
