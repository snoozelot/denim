#!/bin/bash
# mutexec - Clean wrapper around &>/dev/null
#
# WHAT IT DOES
# Runs COMMAND with both stdout and stderr redirected to /dev/null.
# Stdout and stderr are both suppressed. Exit code passes through.
#
# WHY
# &>/dev/null is punctuation, not prose. mutexec names the intent:
# suppress everything. Mute means total silence.
#
# HOW IT WORKS
# exec replaces the shell with COMMAND, redirecting fd 1 and 2 to
# /dev/null before doing so.
#
# USAGE: mutexec COMMAND [ARGS...]
#
# OPTIONS: none
#
# EXAMPLES
#   mutexec npm install          # sudo apt -qq noise
#   mutexec curl -sL url         # suppress progress output
#
# EXIT CODES: passes through COMMAND's exit code
# DEPENDENCIES: bash only

exec "$@" &>/dev/null
