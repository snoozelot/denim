#!/bin/bash
# cronic — Run commands quietly unless they fail
#
# WHAT IT DOES
#
# Executes a bash script silently, only producing output if the command
# fails (non-zero exit). Tailored for cron jobs where stdout/stderr is
# noise unless something breaks.
#
# WHY
#
# Cron mails every line of output by default. Most jobs are silent on
# success. Cronic suppresses success output and surfaces only failures,
# keeping mailboxes clean while preserving full logs for forensics.
#
# HOW IT WORKS
#
#   - Expands placeholders (ISOSTAMP, PID, RANDOM) in LOG_FILE
#   - Captures stdout and stderr separately with timestamps via ts
#   - Logs PWD, ARGV, and EXIT status for debugging
#   - On success: suppresses all output, writes full log to LOG_FILE
#   - On failure: prints stdout/stderr, writes full log to LOG_FILE
#   - Temporary files cleaned up automatically
#   - Exit status of the original command is preserved
#
# USAGE
#
#   cronic LOG_FILE SCRIPT
#
# OPTIONS
#
#   None. Positional arguments only.
#
# EXAMPLES
#
#   cronic /var/log/backup-ISOSTAMP.log /usr/local/bin/backup.sh
#   cronic /tmp/db-ISOSTAMP.log 'pg_dump mydb > /backup/db.sql'
#
# EXIT CODES
#
#   0 — command completed successfully (no output shown)
#   1 — missing or invalid arguments
#   * — exit code of the wrapped command (shown on failure)
#
# DEPENDENCIES
#
#   ts (moreutils) — timestamping log entries
#   sed (POSIX) — placeholder expansion
#   date (POSIX) — ISO timestamp generation

set -euo pipefail

# --- config ---

TIMESPEC="%b %d %H:%M:%.S"

# --- predicates ---

failed()    { [[ $1 -ne 0 ]]; }
has_args()  { [[ $# -ge 2 ]]; }

# --- actions ---

usage() {
    echo "Usage: $0 LOG_FILE SCRIPT" >&2
    echo "Run bash SCRIPT quietly unless it fails, log to LOG_FILE" >&2
    echo "Placeholders: ISOSTAMP, PID, RANDOM" >&2
    exit 1
}

expand_placeholders() {
    local TEMPLATE="$1"
    local STAMP="$2"

    echo "$TEMPLATE" \
    | sed -e "s/ISOSTAMP/${STAMP}/g" \
          -e "s/PID/$$/g" \
          -e "s/RANDOM/${RANDOM}/g"
}

ts_log() {
    local FILE="$1"
    ts "$TIMESPEC" >> "$FILE"
}

log_context() {
    local FILE="$1"
    local KEY="$2"

    shift 2
    printf '%s %s\n' "$KEY" "$*" | ts_log "$FILE"
}

cleanup() {
    rm -f "$STDOUT_LOG" "$STDERR_LOG"
}

output_on_failure() {
    local STATUS="$1"
    failed "$STATUS" || return 0
    cat "$STDOUT_LOG" >&1
    cat "$STDERR_LOG" >&2
}

log_join() {
    { cat "$STDOUT_LOG" "$STDERR_LOG"; echo; } >> "$LOG"
}

# --- main ---

has_args "$@" || usage

TIMESTAMP=$(date +%Y%m%dT%H%M%S)

LOG=$(expand_placeholders "$1" "$TIMESTAMP")
STDOUT_LOG="${LOG}-stdout"
STDERR_LOG="${LOG}-stderr"
shift
SCRIPT="$*"

trap cleanup EXIT INT TERM HUP
touch "$LOG" "$STDOUT_LOG" "$STDERR_LOG"

log_context "$STDOUT_LOG" PWD "$PWD"
log_context "$STDOUT_LOG" ARGV "$0" "$LOG" "$SCRIPT"

bash -c "$SCRIPT" \
    1> >(ts "$TIMESPEC STDOUT" >> "$STDOUT_LOG") \
    2> >(ts "$TIMESPEC STDERR" >> "$STDERR_LOG") \
    || STATUS=$?

STATUS=${STATUS:-0}

# wait for process substitutions (ts pipelines) to finish writing
wait

log_context "$STDERR_LOG" EXIT "$STATUS"
output_on_failure "$STATUS"
log_join
exit "$STATUS"
