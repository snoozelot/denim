#!/usr/bin/env bash
# arc — Universal archive tool
#
# WHAT IT DOES
#
# Wrapper for common archive formats. Detects format by extension and
# dispatches to the right tool. Compound formats (tar.gz, tgz, …) work
# by either direct type dispatch (tgz, tbz2, …) or by peeking one level
# in (gz → strip extension → tar → use tar -xzf). Smart extraction puts
# multiple top-level entries in a subdirectory named after the archive
# with handled extensions stripped.
#
# WHY
#
# Each type owns all its operations in one place. Adding a format means
# adding one type function and one dispatch line — nothing else changes.
# Type enumeration happens once in type_dispatch; cmd_* handle only
# command-level concerns (argument validation, tarbomb detection, dest
# resolution) and delegate tool invocation to the type.
#
# HOW IT WORKS
#
# 1. detect_type — maps filename extension to a type token
# 2. type_dispatch — maps type token to its handler function
# 3. type_X — owns extract/list/paths/create/test for type X
#    - aliases (tgz, tbz2, …): direct tar invocation
#    - bare compressors (gz, bz2, …): peek one level in; if inner is
#      tar, delegate to tar; otherwise single-file compress/decompress
#    - containers (zip, 7z, …): direct tool invocation
# 4. cmd_* — validate args, detect type, resolve dest, call type_dispatch
#
# USAGE
#
#   arc x ARCHIVE [DIR]     Extract archive (to DIR if specified)
#   arc l ARCHIVE           List contents
#   arc c ARCHIVE FILES...  Create archive (format from extension)
#   arc t ARCHIVE           Test archive integrity
#
# EXAMPLES
#
#   arc x backup.tar.gz              Extract to current dir
#   arc x backup.tar.gz /tmp         Extract to /tmp
#   arc l archive.zip                List contents
#   arc c project.tar.xz src/ doc/   Create archive
#   arc t release.tbz2               Test integrity
#
# SUPPORTED FORMATS
#
#   Aliases:     tgz tbz2 tbz txz tzst tlz tbr
#   Compressors: gz bz2 xz zst lz4 lzma lz br sz bz3
#   Containers:  tar zip 7z rar lzh cab ace
#                deb rpm cpio ar
#                exe (Inno Setup)
#                cbz cbr cb7 cbt (comic books)
#                iso (disk images)

set -euo pipefail

# ============================================================================
# Utilities
# ============================================================================

die()              { printf '%s\n' "$*" >&2; exit 1; }
file_exists()      { [[ -f $1 ]]; }
path_exists()      { [[ -e $1 ]]; }
has_arguments()    { [[ $# -gt 0 ]]; }
single_file_only() { [[ $# -eq 1 ]]; }
has_files()        { [[ $# -ge 2 ]]; }  # archive + at least one source

# ============================================================================
# Type detection
# ============================================================================

detect_type() {
    local F=$1
    case "${F,,}" in
        # tar aliases — must precede their base compressor extensions
        *.tgz)               echo "tgz"  ;;
        *.tbz2)              echo "tbz2" ;;
        *.tbz)               echo "tbz"  ;;
        *.txz)               echo "txz"  ;;
        *.tzst)              echo "tzst" ;;
        *.tlz)               echo "tlz"  ;;
        *.tbr)               echo "tbr"  ;;
        # bare compressors
        *.gz)                echo "gz"   ;;
        *.bz2)               echo "bz2"  ;;
        *.xz)                echo "xz"   ;;
        *.zst)               echo "zst"  ;;
        *.lz4)               echo "lz4"  ;;
        *.lzma)              echo "lzma" ;;
        *.lz)                echo "lz"   ;;
        *.br)                echo "br"   ;;
        *.sz)                echo "sz"   ;;
        *.bz3)               echo "bz3"  ;;
        # containers
        *.tar)               echo "tar"  ;;
        *.zip|*.jar|*.war|*.apk) echo "zip"  ;;
        *.7z)                echo "7z"   ;;
        *.rar)               echo "rar"  ;;
        *.lzh|*.lha)         echo "lzh"  ;;
        *.cab)               echo "cab"  ;;
        *.ace)               echo "ace"  ;;
        *.deb)               echo "deb"  ;;
        *.rpm)               echo "rpm"  ;;
        *.cpio)              echo "cpio" ;;
        *.a|*.ar)            echo "ar"   ;;
        *.exe)               echo "exe"  ;;
        *.cbz)               echo "cbz"  ;;
        *.cbr)               echo "cbr"  ;;
        *.cb7)               echo "cb7"  ;;
        *.cbt)               echo "cbt"  ;;
        *.iso)               echo "iso"  ;;
        *)                   die "Unknown archive type: $F" ;;
    esac
}

# ============================================================================
# Basename stripping
# ============================================================================

# Strips exactly the extensions handled during extraction.
# Always strips one extension; strips a second if INNER is tar
# (bare compressor over tar, e.g. file.tar.gz -> file).
subdir_name() {
    local ARCHIVE=$1
    local INNER=${2:-}
    local F="${ARCHIVE##*/}"

    F="${F%.*}"
    if [[ $INNER == tar ]]; then
        F="${F%.*}"
    fi
    echo "$F"
}

# ============================================================================
# Type handlers
#
# Calling convention: type_X OP ARCHIVE [ARG...]
#
#   OP       $3 / ${@:3}
#   -------  ----------------------
#   extract  DEST
#   list     (none)
#   paths    (none)  — one path per line, for tarbomb detection
#   create   FILES...
#   test     (none)
# ============================================================================

# --- tar aliases ---

type_tgz() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) tar -xzf    "$ARCHIVE" -C "$3" ;;
        list)    tar -tzf    "$ARCHIVE" ;;
        paths)   tar -tzf    "$ARCHIVE" ;;
        create)  tar -czf    "$ARCHIVE" "${@:3}" ;;
        test)    tar -tzf    "$ARCHIVE" > /dev/null ;;
    esac
}

type_tbz2() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) tar -xjf    "$ARCHIVE" -C "$3" ;;
        list)    tar -tjf    "$ARCHIVE" ;;
        paths)   tar -tjf    "$ARCHIVE" ;;
        create)  tar -cjf    "$ARCHIVE" "${@:3}" ;;
        test)    tar -tjf    "$ARCHIVE" > /dev/null ;;
