# --- containers ---

type_tar() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) tar -xf  "$ARCHIVE" -C "$3" ;;
        list)    tar -tf  "$ARCHIVE" ;;
        paths)   tar -tf  "$ARCHIVE" ;;
        create)  tar -cf  "$ARCHIVE" "${@:3}" ;;
        test)    tar -tf  "$ARCHIVE" > /dev/null ;;
    esac
}

type_zip() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) unzip -q  "$ARCHIVE" -d "$3" ;;
        list)    unzip -l  "$ARCHIVE" ;;
        paths)   unzip -Z1 "$ARCHIVE" ;;
        create)  zip -r    "$ARCHIVE" "${@:3}" ;;
        test)    unzip -t  "$ARCHIVE" ;;
    esac
}

type_7z() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) 7z x -o"$3" "$ARCHIVE" ;;
        list)    7z l        "$ARCHIVE" ;;
        paths)   7z l -slt   "$ARCHIVE" | sed -n 's/^Path = //p' | tail -n +2 ;;
        create)  7z a        "$ARCHIVE" "${@:3}" ;;
        test)    7z t        "$ARCHIVE" ;;
    esac
}

type_rar() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) unrar x "$ARCHIVE" "$3/" ;;
        list)    unrar l "$ARCHIVE" ;;
        paths)   unrar lb "$ARCHIVE" ;;
        create)  rar a   "$ARCHIVE" "${@:3}" ;;
        test)    unrar t "$ARCHIVE" ;;
    esac
}

type_lzh() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) lha xw="$3" "$ARCHIVE" ;;
        list)    lha l       "$ARCHIVE" ;;
        paths)   lha l       "$ARCHIVE" | awk 'NR>2 {print $NF}' ;;
        create)  lha c       "$ARCHIVE" "${@:3}" ;;
        test)    lha t       "$ARCHIVE" ;;
    esac
}

type_cab() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract)
            if unshield t "$ARCHIVE" &>/dev/null; then
                unshield -d "$3" x "$ARCHIVE"
            else
                cabextract -d "$3" "$ARCHIVE"
            fi ;;
        list)    cabextract -l "$ARCHIVE" ;;
        paths)   cabextract -l "$ARCHIVE" | awk 'NR>3 {print $NF}' ;;
        create)  die "Cannot create cab archives" ;;
        test)    cabextract -t "$ARCHIVE" ;;
    esac
}

type_ace() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) unace x -p "$3/" "$ARCHIVE" ;;
        list)    unace l    "$ARCHIVE" ;;
        paths)   unace l    "$ARCHIVE" | awk 'NR>7 {print $NF}' ;;
        create)  die "Cannot create ace archives" ;;
        test)    unace t    "$ARCHIVE" ;;
    esac
}

type_deb() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) dpkg-deb -x    "$ARCHIVE" "$3" ;;
        list)    dpkg-deb -c    "$ARCHIVE" ;;
        paths)   dpkg-deb -c    "$ARCHIVE" | awk '{print $NF}' ;;
        create)  die "Cannot create deb archives" ;;
        test)    dpkg-deb --info "$ARCHIVE" > /dev/null ;;
    esac
}

type_rpm() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) rpm2cpio "$ARCHIVE" | cpio -idm -D "$3" ;;
        list)    rpm -qlp  "$ARCHIVE" ;;
        paths)   rpm -qlp  "$ARCHIVE" ;;
        create)  die "Cannot create rpm archives" ;;
        test)    rpm --checksig "$ARCHIVE" ;;
    esac
}

type_cpio() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) cpio -idm -D "$3" < "$ARCHIVE" ;;
        list)    cpio -t       < "$ARCHIVE" ;;
        paths)   cpio -t       < "$ARCHIVE" ;;
        create)  cpio -o > "$ARCHIVE" ;;
        test)    cpio -t       < "$ARCHIVE" > /dev/null ;;
    esac
}

type_ar() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) ar x --output="$3" "$ARCHIVE" ;;
        list)    ar t "$ARCHIVE" ;;
        paths)   ar t "$ARCHIVE" ;;
        create)  ar r "$ARCHIVE" "${@:3}" ;;
        test)    ar t "$ARCHIVE" > /dev/null ;;
    esac
}

type_exe() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) innoextract -d "$3" "$ARCHIVE" ;;
        list)    innoextract -l "$ARCHIVE" ;;
        paths)   innoextract -l "$ARCHIVE" | sed -n 's/^ - //p' ;;
        create)  die "Cannot create exe archives" ;;
        test)    innoextract -t "$ARCHIVE" ;;
    esac
}

# ============================================================================
# Dispatch — type enumeration happens exactly once
# ============================================================================

type_dispatch() {
    local TYPE=$1
    shift
    case "$TYPE" in
        tgz)        type_tgz  "$@" ;;
        tbz2|tbz)   type_tbz2 "$@" ;;
        txz)        type_txz  "$@" ;;
        tzst)       type_tzst "$@" ;;
        tlz)        type_tlz  "$@" ;;
        tbr)        type_tbr  "$@" ;;
        gz)         type_gz   "$@" ;;
        bz2)        type_bz2  "$@" ;;
        xz)         type_xz   "$@" ;;
        zst)        type_zst  "$@" ;;
        lzma)       type_lzma "$@" ;;
        lz)         type_lz   "$@" ;;
        lz4)        type_lz4  "$@" ;;
        br)         type_br   "$@" ;;
        sz)         type_sz   "$@" ;;
        bz3)        type_bz3  "$@" ;;
        tar|cbt)    type_tar  "$@" ;;
        zip|cbz)    type_zip  "$@" ;;
        7z|cb7|iso) type_7z   "$@" ;;
        rar|cbr)    type_rar  "$@" ;;
        lzh)        type_lzh  "$@" ;;
        cab)        type_cab  "$@" ;;
        ace)        type_ace  "$@" ;;
        deb)        type_deb  "$@" ;;
        rpm)        type_rpm  "$@" ;;
        cpio)       type_cpio "$@" ;;
        ar)         type_ar   "$@" ;;
        exe)        type_exe  "$@" ;;
    esac
}

# ============================================================================
# Tarbomb detection
# ============================================================================

count_toplevel() {
    local ARCHIVE=$1
    local TYPE=$2
    local LISTING

    LISTING=$(type_dispatch "$TYPE" paths "$ARCHIVE" 2>/dev/null) || LISTING=""
    printf '%s\n' "$LISTING" | sed 's|/.*||' | sort -u | wc -l
}

is_tarbomb() { [[ $(count_toplevel "$1" "$2") -gt 1 ]]; }

resolve_dest() {
    local ARCHIVE=$1
    local TYPE=$2
    local DEST=$3
    local INNER

    INNER=$(detect_type "${ARCHIVE%.*}" 2>/dev/null) || INNER=""
    if is_tarbomb "$ARCHIVE" "$TYPE"; then
        echo "$DEST/$(subdir_name "$ARCHIVE" "$INNER")"
    else
        echo "$DEST"
    fi
}

# ============================================================================
# Commands
# ============================================================================

cmd_extract() {
    local ARCHIVE=$1
    local DEST=${2:-.}
    local TYPE
    local FINAL_DEST

    file_exists "$ARCHIVE" || die "File not found: $ARCHIVE"
    TYPE=$(detect_type "$ARCHIVE")
    FINAL_DEST=$(resolve_dest "$ARCHIVE" "$TYPE" "$DEST")
    if [[ $FINAL_DEST != "$DEST" ]]; then
        path_exists "$FINAL_DEST" && die "Destination already exists: $FINAL_DEST"
        printf 'Extracting to %s/\n' "$FINAL_DEST"
    fi
    mkdir -p "$FINAL_DEST"
    type_dispatch "$TYPE" extract "$ARCHIVE" "$FINAL_DEST"
}

cmd_list() {
    local ARCHIVE=$1
    local TYPE

    file_exists "$ARCHIVE" || die "File not found: $ARCHIVE"
    TYPE=$(detect_type "$ARCHIVE")
    type_dispatch "$TYPE" list "$ARCHIVE"
}

cmd_create() {
    local ARCHIVE=$1
    local TYPE

    shift
    has_arguments "$@" || die "No files specified"
    TYPE=$(detect_type "$ARCHIVE")
    type_dispatch "$TYPE" create "$ARCHIVE" "$@"
}

cmd_test() {
    local ARCHIVE=$1
    local TYPE

    file_exists "$ARCHIVE" || die "File not found: $ARCHIVE"
    TYPE=$(detect_type "$ARCHIVE")
    type_dispatch "$TYPE" test "$ARCHIVE"
    echo "OK"
}

# ============================================================================
# Main
# ============================================================================

usage() {
    cat << 'EOF'
Usage: arc COMMAND ARCHIVE [ARGS...]

Commands:
  x, extract   Extract archive (optional: destination dir)
  l, list      List archive contents
  c, create    Create archive from files
  t, test      Test archive integrity

Formats:
  Aliases:     tgz tbz2 tbz txz tzst tlz tbr
  Compressors: gz bz2 xz zst lz4 lzma lz br sz bz3
  Containers:  tar zip 7z rar lzh cab ace  deb rpm cpio ar  exe
               cbz cbr cb7 cbt (comic books)  iso (disk images)

Examples:
  arc x foo.tar.xz           Extract (auto-creates subdir if needed)
  arc x foo.tgz ./out        Extract to ./out
  arc l foo.zip              List contents
  arc c bar.tzst dir/        Create tzst archive
  arc t foo.7z               Test integrity
EOF
    exit 1
}

main() {
    local CMD

    has_arguments "$@" || usage

    CMD=$1
    shift

    case "$CMD" in
        x|extract) has_arguments    "$@" || usage; cmd_extract "$@" ;;
        l|list)    single_file_only "$@" || usage; cmd_list    "$1" ;;
        c|create)  has_files        "$@" || usage; cmd_create  "$@" ;;
        t|test)    single_file_only "$@" || usage; cmd_test    "$1" ;;
        *)         usage ;;
    esac
}

main "$@"
