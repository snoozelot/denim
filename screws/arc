    esac
}

type_tbr() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) brotli -dc "$ARCHIVE" | tar -xf - -C "$3" ;;
        list)    brotli -dc "$ARCHIVE" | tar -tf - ;;
        paths)   brotli -dc "$ARCHIVE" | tar -tf - ;;
        create)  tar -cf - "${@:3}" | brotli > "$ARCHIVE" ;;
        test)    brotli -dc "$ARCHIVE" | tar -tf - > /dev/null ;;
    esac
}

# --- bare compressors ---
# Peek at inner type: if tar, delegate to tar; otherwise single-file op.

type_gz() {
    local OP=$1
    local ARCHIVE=$2
    local INNER

    INNER=$(detect_type "${ARCHIVE%.*}" 2>/dev/null) || INNER=""
    case "$OP" in
        extract)
            if [[ $INNER == tar ]]; then
                tar -xzf "$ARCHIVE" -C "$3"
            else
                gzip -dc "$ARCHIVE" > "$3/$(subdir_name "$ARCHIVE" "$INNER")"
            fi ;;
        list)
            if [[ $INNER == tar ]]; then
                tar -tzf "$ARCHIVE"
            else
                echo "(compressed: $(subdir_name "$ARCHIVE" "$INNER"))"
            fi ;;
        paths)
            if [[ $INNER == tar ]]; then
                tar -tzf "$ARCHIVE"
            else
                subdir_name "$ARCHIVE" "$INNER"
            fi ;;
        create)
            if [[ $INNER == tar ]]; then
                tar -czf "$ARCHIVE" "${@:3}"
            else
                single_file_only "${@:3}" || die "gz: single file only"
                gzip -c "$3" > "$ARCHIVE"
            fi ;;
        test)
            if [[ $INNER == tar ]]; then
                tar -tzf "$ARCHIVE" > /dev/null
            else
                gzip -t "$ARCHIVE"
            fi ;;
    esac
}

