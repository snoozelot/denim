type_tzst() {
    local OP=$1
    local ARCHIVE=$2
    case "$OP" in
        extract) tar --zstd -xf "$ARCHIVE" -C "$3" ;;
        list)    tar --zstd -tf "$ARCHIVE" ;;
        paths)   tar --zstd -tf "$ARCHIVE" ;;
        create)  tar --zstd -cf "$ARCHIVE" "${@:3}" ;;
