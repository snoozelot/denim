#!/bin/bash
# cyclines - permute input lines via cycle notation
#
# Rearranges input lines using cycle notation where [N M ...] means:
# line at position N moves to position M, etc.
#
# Usage:
#   cyclines [N M ...] < input
#
# Examples:
#   cyclines '[' 1 2 ']' '[' 3 4 ']'  # swap lines 1↔2, 3↔4
#   cyclines '[' 1 2 3 ']'            # rotate: 1→2, 2→3, 3→1
set -euo pipefail

PERM=()
BUF=()
MAX=1
LAST=""

die() { printf '[ERROR] %s\n' "$1" >&2; exit 1; }

is_num()           { [[ $1 =~ ^[1-9][0-9]*$ ]]; }
inside_cycle()     { [[ -n $LAST ]]; }
is_trivial_cycle() { [[ $1 == "$LAST" ]]; }
already_mapped()   { [[ -n ${PERM[$1]:-} ]]; }
has_arguments()    { [[ $# -gt 0 ]]; }

handle_close_bracket() {
    inside_cycle && die "nested cycle at position $POS"
    return 0
}

handle_open_bracket() {
    inside_cycle || die "unmatched '[' at position $POS"
    is_num "$NEXT" || die "expected integer at position $((POS+1))"
    is_trivial_cycle "$NEXT" && { LAST=""; return 0; }
    already_mapped "$LAST" && die "collision at position $((POS+1))"
    PERM[$LAST]=$NEXT
    LAST=""
}

handle_chain_element() {
    is_num "$NEXT" || die "expected integer at position $((POS+1))"
    already_mapped "$ARG" && die "collision at position $POS"
    PERM[$ARG]=$NEXT
}

handle_number() {
    (( ARG > MAX )) && MAX=$ARG
    
    inside_cycle || {
        [[ "$NEXT" == ']' ]] && { LAST=$ARG; return 0; }
        die "cycle element missing ']' at position $POS"
    }
    
    handle_chain_element
}

handle_token() {
    if [[ "$ARG" == ']' ]]; then
        handle_close_bracket
    elif [[ "$ARG" == '[' ]]; then
        handle_open_bracket
    elif is_num "$ARG"; then
        handle_number
    else
        die "expected integer, '[', or ']' at position $POS"
    fi
}

parse_arguments() {
    local NPOS
    for (( POS=$#; POS>0; --POS )); do
        ARG=${!POS}
        if (( POS < $# )); then
            NPOS=$((POS+1))
            NEXT=${!NPOS}
        else
            NEXT=""
        fi
        handle_token
    done
}

print_buffered_lines() {
    local FROM=$1 TO=$2
    for (( J=FROM; J<=TO; ++J )); do
        [[ -n ${BUF[$J]:-} ]] && printf '%s\n' "${BUF[$J]}"
    done
}

validate_permutation() {
    local TOTAL=$1 POS
    for POS in "${!PERM[@]}"; do
        (( POS > TOTAL )) && die "position $POS exceeds input size $TOTAL"
        (( PERM[$POS] > TOTAL )) && die "target ${PERM[$POS]} exceeds input size $TOTAL"
    done
    return 0
}

permute_lines() {
    local ID=0 FLUSH_FROM=1 LINE TARGET HIGHEST=0
    local -a LINES=()
    
    while IFS= read -r LINE || [[ -n $LINE ]]; do
        (( ++ID ))
        LINES[$ID]=$LINE
    done
    
    validate_permutation "$ID"
    
    for (( POS=1; POS<=ID; POS++ )); do
        TARGET=${PERM[$POS]:-$POS}
        BUF[$TARGET]=${LINES[$POS]}
    done
    
    print_buffered_lines 1 "$ID"
}

has_arguments "$@" || die "usage: cyclines [ N M ... ]"

parse_arguments "$@"
permute_lines
