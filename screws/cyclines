#!/bin/bash
# cyclines — permute input lines via cycle notation
#
# WHAT IT DOES
#
# Rearranges input lines using cycle notation. Numbers refer to
# line positions (1-indexed). A sequence N M ... P means line N
# moves to position M, line M to the next, and line P wraps back
# to N.
#
# Cycles are separated by `--` or introduced with `--cycle`.
# The first cycle is implicit — bare numbers start a cycle.
#
# USAGE
#
#   cyclines [--cycle] N M ... [-- N M ...] < input
#
# EXAMPLES
#
#   cyclines 1 2 -- 3 4 5   # swap 1↔2, rotate 3→4→5→3
#   cyclines --cycle 1 2 --cycle 3 4 5  # same, explicit
#   cyclines --cycle 1 2 3  # rotate: 1→2, 2→3, 3→1
set -euo pipefail

PERM=()
BUF=()
CYCLE=()

die()            { printf '[ERROR] %s\n' "$1" >&2; exit 1; }
is_num()         { [[ $1 =~ ^[1-9][0-9]*$ ]]; }
already_mapped() { [[ -n ${PERM[$1]:-} ]]; }
has_arguments()  { [[ $# -gt 0 ]]; }

map_cycle() {
    local LEN=${#CYCLE[@]}
    [[ $LEN -le 1 ]] && return 0
    local I
    local TAIL

    for (( I=0; I<LEN-1; I++ )); do
        if already_mapped "${CYCLE[$I]}"; then die "duplicate position ${CYCLE[$I]}"; fi
        PERM[${CYCLE[$I]}]=${CYCLE[$((I+1))]}
    done

    TAIL=${CYCLE[$((LEN-1))]}
    if already_mapped "$TAIL"; then die "duplicate position $TAIL"; fi
    PERM[$TAIL]=${CYCLE[0]}
}

parse_arguments() {
    local ARG

    for ARG in "$@"; do
        if [[ "$ARG" == '--cycle' ]] || [[ "$ARG" == '--' ]]; then
            if [[ ${#CYCLE[@]} -gt 0 ]]; then
                map_cycle
                CYCLE=()
            fi
        elif is_num "$ARG"; then
            CYCLE+=("$ARG")
        else
            die "expected number, '--cycle', or '--', got: $ARG"
        fi
    done

    if [[ ${#CYCLE[@]} -gt 0 ]]; then
        map_cycle
    fi
}

validate_permutation() {
    local TOTAL=$1
    local POS

    for POS in "${!PERM[@]}"; do
        (( POS > TOTAL )) && die "position $POS exceeds input size $TOTAL"
        (( PERM[$POS] > TOTAL )) && die "target ${PERM[$POS]} exceeds input size $TOTAL"
    done
    return 0
}

print_buffered_lines() {
    local FROM=$1
    local TO=$2
    local J

    for (( J=FROM; J<=TO; ++J )); do
        [[ -n ${BUF[$J]:-} ]] && printf '%s\n' "${BUF[$J]}"
    done
}

permute_lines() {
    local ID=0
    local LINE
    local TARGET
    local POS
    local -a LINES=()

    while IFS= read -r LINE || [[ -n $LINE ]]; do
        (( ++ID ))
        LINES[$ID]=$LINE
    done

    validate_permutation "$ID"

    for (( POS=1; POS<=ID; POS++ )); do
        TARGET=${PERM[$POS]:-$POS}
        BUF[$TARGET]=${LINES[$POS]}
    done

    print_buffered_lines 1 "$ID"
}

has_arguments "$@" || die "usage: cyclines [--cycle] N M ... [-- N M ...]"

parse_arguments "$@"
permute_lines
