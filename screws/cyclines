#!/bin/bash
# cyclines — permute input lines via cycle notation
#
# WHAT IT DOES
#
# Rearranges input lines using cycle notation where [N M ...] means:
# line at position N moves to position M, M to the next, and the last
# position maps back to N.
#
# USAGE
#
#   cyclines [ N M ... ] < input
#
# EXAMPLES
#
#   cyclines [ 1 2 ] [ 3 4 ]  # swap lines 1↔2, 3↔4
#   cyclines [ 1 2 3 ]        # rotate: 1→2, 2→3, 3→1
set -euo pipefail

PERM=()
BUF=()
CYCLE=()
IN_CYCLE=false

die()            { printf '[ERROR] %s\n' "$1" >&2; exit 1; }
is_num()         { [[ $1 =~ ^[1-9][0-9]*$ ]]; }
is_in_cycle()    { [[ "$IN_CYCLE" == true ]]; }
already_mapped() { [[ -n ${PERM[$1]:-} ]]; }
has_arguments()  { [[ $# -gt 0 ]]; }

map_cycle() {
    local LEN=${#CYCLE[@]}
    [[ $LEN -le 1 ]] && return 0
    local I
    local TAIL

    for (( I=0; I<LEN-1; I++ )); do
        if already_mapped "${CYCLE[$I]}"; then die "duplicate position ${CYCLE[$I]}"; fi
        PERM[${CYCLE[$I]}]=${CYCLE[$((I+1))]}
    done

    TAIL=${CYCLE[$((LEN-1))]}
    if already_mapped "$TAIL"; then die "duplicate position $TAIL"; fi
    PERM[$TAIL]=${CYCLE[0]}
}

parse_arguments() {
    local POS
    local ARG

    for (( POS=1; POS<=$#; POS++ )); do
        ARG=${!POS}
        if [[ "$ARG" == '[' ]]; then
            if is_in_cycle; then die "nested '[' at position $POS"; fi
            IN_CYCLE=true
            CYCLE=()
        elif [[ "$ARG" == ']' ]]; then
            is_in_cycle || die "unmatched ']' at position $POS"
            map_cycle
            IN_CYCLE=false
        elif is_num "$ARG"; then
            is_in_cycle || die "number $ARG outside cycle at position $POS"
            CYCLE+=("$ARG")
        else
            die "expected integer, '[', or ']' at position $POS"
        fi
    done

    if is_in_cycle; then die "unclosed '['"; fi
}

validate_permutation() {
    local TOTAL=$1
    local POS

    for POS in "${!PERM[@]}"; do
        (( POS > TOTAL )) && die "position $POS exceeds input size $TOTAL"
        (( PERM[$POS] > TOTAL )) && die "target ${PERM[$POS]} exceeds input size $TOTAL"
    done
    return 0
}

print_buffered_lines() {
    local FROM=$1
    local TO=$2
    local J

    for (( J=FROM; J<=TO; ++J )); do
        [[ -n ${BUF[$J]:-} ]] && printf '%s\n' "${BUF[$J]}"
    done
}

permute_lines() {
    local ID=0
    local LINE
    local TARGET
    local POS
    local -a LINES=()

    while IFS= read -r LINE || [[ -n $LINE ]]; do
        (( ++ID ))
        LINES[$ID]=$LINE
    done

    validate_permutation "$ID"

    for (( POS=1; POS<=ID; POS++ )); do
        TARGET=${PERM[$POS]:-$POS}
        BUF[$TARGET]=${LINES[$POS]}
    done

    print_buffered_lines 1 "$ID"
}

has_arguments "$@" || die "usage: cyclines [ N M ... ]"

parse_arguments "$@"
permute_lines
