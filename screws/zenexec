#!/bin/bash
# zenexec - Clean wrapper around &>/dev/null
#
# WHAT IT DOES
# Runs COMMAND with both stdout and stderr redirected to /dev/null.
# Exit code passes through.
#
# WHY
# &>/dev/null is punctuation, not prose. zenexec names the intent:
# complete output suppression. One word instead of a glyph.
#
# HOW IT WORKS
# exec replaces the shell with COMMAND, redirecting fd 1 and 2 to
# /dev/null before doing so.
#
# USAGE: zenexec COMMAND [ARGS...]
#
# OPTIONS: none
#
# EXAMPLES
#   zenexec npm install        # &>/dev/null
#   zenexec curl -sL url       # double silence
#
# EXIT CODES: passes through COMMAND's exit code
# DEPENDENCIES: bash only

exec "$@" &>/dev/null
