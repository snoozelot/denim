#!/bin/bash
# zenexec - Clean wrapper around 2>/dev/null
#
# WHAT IT DOES
# Runs COMMAND with stderr redirected to /dev/null. Stdout and exit code
# pass through unchanged.
#
# WHY
# 2>/dev/null is punctuation, not prose. zenexec names the intent:
# filter noise, keep signal. Like zen cutting through distraction.
#
# HOW IT WORKS
# exec replaces the shell with COMMAND, redirecting fd 2 to /dev/null
# before doing so.
#
# USAGE: zenexec COMMAND [ARGS...]
#
# OPTIONS: none
#
# EXAMPLES
#   zenexec rsync -a src/ dst/     # suppress diagnostic noise
#   zenexec apt-get install tree   # noise out, info visible
#
# EXIT CODES: passes through COMMAND's exit code
# DEPENDENCIES: bash only

exec "$@" 2>/dev/null
