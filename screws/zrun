#!/usr/bin/env bash
# zrun — Run command with transparently decompressed file arguments
#
# WHAT IT DOES
#
# Any compressed file arguments are decompressed to temp files, and the
# command runs with decompressed versions. Temp files are cleaned up after.
#
# DEPENDENCIES
#
# Requires decompression tools for formats in use: gunzip, bunzip2, xz, zstd,
# lz4, lzma/lzip, brotli, snzip, bzip3, uncompress, lzop. Missing tools cause
# runtime errors only if that compression format is used.
#
# USAGE
#
#   zrun COMMAND [ARGS...]
#   zCOMMAND [ARGS...]          (when symlinked as zless, zcat, etc.)
#
# SUPPORTED FORMATS
#
#   gz, bz2, xz, zst, lz4, lzma, lz, br, sz, bz3, Z, lzo
#
# EXAMPLES
#
#   zrun vim file.txt.gz       Open compressed file in vim
#   zrun diff a.txt.xz b.txt   Diff compressed vs uncompressed
#   zrun wc -l *.log.zst       Word count on multiple compressed files
#
# SYMLINK USAGE
#
#   ln -s zrun zvim            Then: zvim file.gz

set -euo pipefail

TEMPFILES=()

cleanup() {
    local F
    for F in "${TEMPFILES[@]}"; do
        rm -f "$F"
    done
}

trap cleanup EXIT

die() { printf '%s\n' "$*" >&2; exit 1; }

has_arguments() { [[ $# -ge 1 ]]; }

invoked_as_symlink() { [[ "$1" == z* && "$1" != "zrun" ]]; }

# SIDEFF: TEMPFILES, PROCESSED
decomp() {
    local FILE=$1
    local EXT
    local TEMPFILE

    [[ -f "$FILE" ]] || { PROCESSED+=("$FILE"); return 0; }

    EXT=${FILE##*.}
    TEMPFILE=$(mktemp)
    TEMPFILES+=("$TEMPFILE")
    case "${EXT,,}" in
        gz)   gunzip -c     < "$FILE" > "$TEMPFILE" ;;
        bz2)  bunzip2 -c    < "$FILE" > "$TEMPFILE" ;;
        xz)   xz -dc        < "$FILE" > "$TEMPFILE" ;;
        zst)  zstd -dc      < "$FILE" > "$TEMPFILE" ;;
        lz4)  lz4 -dc       < "$FILE" > "$TEMPFILE" ;;
        lzma) lzma -dc      < "$FILE" > "$TEMPFILE" ;;
        lz)   lzip -dc      < "$FILE" > "$TEMPFILE" ;;
        br)   brotli -dc    < "$FILE" > "$TEMPFILE" ;;
        sz)   snunzip -c    < "$FILE" > "$TEMPFILE" ;;
        bz3)  bzip3 -dc     < "$FILE" > "$TEMPFILE" ;;
        z)    uncompress -c < "$FILE" > "$TEMPFILE" ;;
        lzo)  lzop -dc      < "$FILE" > "$TEMPFILE" ;;
        *)    rm -f "$TEMPFILE"; PROCESSED+=("$FILE"); return 0 ;;
    esac
    PROCESSED+=("$TEMPFILE")
}

usage() {
    cat << 'EOF'
Usage: zrun COMMAND [ARGS...]

Run command with compressed files transparently decompressed.

Supported: gz, bz2, xz, zst, lz4, lzma, lz, br, sz, bz3, Z, lzo

Examples:
  zrun vim file.txt.gz
  zrun diff a.txt.xz b.txt.bz2
  zrun grep pattern *.log.zst

Symlink usage:
  ln -s zrun zvim
  zvim file.gz
EOF
    exit 1
}

main() {
    local CMD
    local INVOKED

    INVOKED=$(basename "$0")
    if invoked_as_symlink "$INVOKED"; then
        CMD=${INVOKED#z}
    else
        has_arguments "$@" || usage
        CMD=$1
        shift
    fi

    has_arguments "$@" || usage

    PROCESSED=()
    for ARG in "$@"; do decomp "$ARG"; done

    # Cannot exec: that would replace the shell and skip the EXIT trap, leaking tempfiles.
    # Run normally; set -e propagates a nonzero exit code, then the trap cleans up.
    "$CMD" "${PROCESSED[@]}"
}

main "$@"
