#!/usr/bin/env bash
# zrun — Run command with transparently decompressed file arguments
#
# WHAT IT DOES
#
# Any compressed file arguments are decompressed to temp files, and the
# command runs with decompressed versions. Temp files are cleaned up after.
#
# USAGE
#
#   zrun COMMAND [ARGS...]
#   zCOMMAND [ARGS...]          (when symlinked as zless, zcat, etc.)
#
# SUPPORTED FORMATS
#
#   gz, bz2, xz, zst, lz4, lzma, lz, br, sz, bz3, Z, lzo
#
# EXAMPLES
#
#   zrun vim file.txt.gz       Open compressed file in vim
#   zrun diff a.txt.xz b.txt   Diff compressed vs uncompressed
#   zrun wc -l *.log.zst       Word count on multiple compressed files
#
# SYMLINK USAGE
#
#   ln -s zrun zvim            Then: zvim file.gz

set -euo pipefail

TEMPFILES=()

cleanup() {
    local F
    for F in "${TEMPFILES[@]}"; do
        rm -f "$F"
    done
}

trap cleanup EXIT

die() { printf '%s\n' "$*" >&2; exit 1; }

# ============================================================================
# Decompression
# ============================================================================

# Decompress SRC into DEST. Returns 1 if SRC is not a recognized format.
try_decompress() {
    local SRC=$1
    local DEST=$2
    case "${SRC,,}" in
        *.gz)   gunzip      -c "$SRC" > "$DEST" ;;
        *.bz2)  bunzip2     -c "$SRC" > "$DEST" ;;
        *.xz)   xz         -dc "$SRC" > "$DEST" ;;
        *.zst)  zstd       -dc "$SRC" > "$DEST" ;;
        *.lz4)  lz4        -dc "$SRC" > "$DEST" ;;
        *.lzma) lzma       -dc "$SRC" > "$DEST" ;;
        *.lz)   lzip       -dc "$SRC" > "$DEST" ;;
        *.br)   brotli     -dc "$SRC" > "$DEST" ;;
        *.sz)   snunzip     -c "$SRC" > "$DEST" ;;
        *.bz3)  bzip3      -dc "$SRC" > "$DEST" ;;
        *.z)    uncompress  -c "$SRC" > "$DEST" ;;
        *.lzo)  lzop       -dc "$SRC" > "$DEST" ;;
        *)      return 1 ;;
    esac
}

# ============================================================================
# Argument processing
# ============================================================================

process_args() {
    local ARGS=()
    local ARG
    local TEMPFILE

    for ARG in "$@"; do
        if [[ -f "$ARG" ]]; then
            TEMPFILE=$(mktemp --suffix="-$(basename "${ARG%.*}")")
            TEMPFILES+=("$TEMPFILE")
            if try_decompress "$ARG" "$TEMPFILE"; then
                ARGS+=("$TEMPFILE")
            else
                ARGS+=("$ARG")
            fi
        else
            ARGS+=("$ARG")
        fi
    done

    printf '%s\0' "${ARGS[@]}"
}

# ============================================================================
# Main
# ============================================================================

usage() {
    cat << 'EOF'
Usage: zrun COMMAND [ARGS...]

Run command with compressed files transparently decompressed.

Supported: gz, bz2, xz, zst, lz4, lzma, lz, br, sz, bz3, Z, lzo

Examples:
  zrun vim file.txt.gz
  zrun diff a.txt.xz b.txt.bz2
  zrun grep pattern *.log.zst

Symlink usage:
  ln -s zrun zvim
  zvim file.gz
EOF
    exit 1
}

INVOKED=$(basename "$0")
if [[ "$INVOKED" == z* && "$INVOKED" != "zrun" ]]; then
    CMD="${INVOKED#z}"
else
    [[ $# -ge 1 ]] || usage
    CMD=$1
    shift
fi

[[ $# -ge 1 ]] || usage

mapfile -d '' PROCESSED < <(process_args "$@")
exec "$CMD" "${PROCESSED[@]}"
