#!/bin/bash
# slay — Kill processes with SIGKILL
#
# WHAT IT DOES
#
# Sends SIGKILL to one or more processes. Shorthand for kill -SIGKILL.
#
# USAGE
#
#   slay PID...
#
# EXAMPLES
#
#   slay 12345                # kill single process
#   slay $(pgrep firefox)     # kill all firefox processes

exec kill -SIGKILL "$@"
