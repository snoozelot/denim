#!/usr/bin/env bash
# cidr-host — Calculate host IP address within CIDR prefix (Tofu/Terraform compatible)
#
# WHAT IT DOES
#
# Implements cidrhost(prefix, hostnum) from OpenTofu.
# Returns the full host IP address for a given host number within a network prefix.
# Negative hostnum counts from end of range.
#
# USAGE
#
#   cidr-host PREFIX HOSTNUM
#
# EXAMPLES
#
#   cidr-host 10.12.112.0/20 16      → 10.12.112.16
#   cidr-host 10.12.112.0/20 268     → 10.12.113.12
#   cidr-host 10.0.0.0/8 -2          → 10.255.255.254
#   cidr-host fd00:fd12:3456:7890:00a2::/72 34  → fd00:fd12:3456:7890::22

set -euo pipefail

# ============================================================================
# Constants
# ============================================================================

IPV4_BITS=32
IPV6_BITS=128
IPV6_GROUPS=8
BITS_PER_NIBBLE=4
IPV6_HEX_LEN=32
BASH_SAFE_BITS=63
MIN_COMPRESS_RUN=2

# ============================================================================
# Interface
# ============================================================================

die() { printf '%s\n' "$*" >&2; exit 1; }

usage() {
    cat <<'EOF'
Usage: cidr-host PREFIX HOSTNUM

Calculate host IP address within CIDR prefix (Tofu/Terraform compatible).

Arguments:
  PREFIX   Network in CIDR notation (e.g., 10.12.112.0/20 or fd00::/64)
  HOSTNUM  Host number (0-indexed, negative counts from end)

Examples:
  cidr-host 10.12.112.0/20 16      → 10.12.112.16
  cidr-host 10.12.112.0/20 268     → 10.12.113.12
  cidr-host 10.0.0.0/8 -2          → 10.255.255.254
  cidr-host fd00:fd12:3456:7890:00a2::/72 34  → fd00:fd12:3456:7890::22
EOF
    exit 1
}

has_arguments() { [[ $# -ge 2 ]]; }

# ============================================================================
# Predicates
# ============================================================================

is_ipv6()               { [[ $1 == *:* ]]; }
is_compressed_ipv6()    { [[ $1 == *::* ]]; }
has_cidr_slash()        { [[ $1 == */* ]]; }
is_integer()            { [[ $1 =~ ^-?[0-9]+$ ]]; }
is_negative()           { [[ $1 -lt 0 ]]; }
fits_in_bash()          { [[ $1 -lt $BASH_SAFE_BITS ]]; }
worth_compressing() { [[ $1 -ge $MIN_COMPRESS_RUN ]]; }
has_host_bits()         { [[ $1 -gt 0 ]]; }

# ============================================================================
# IPv4 operations
# ============================================================================

ipv4_parse() {
    local ADDR=$1
    local IFS='.'
    local -a O

    read -ra O <<< "$ADDR"
    echo $(( (O[0] << 24) | (O[1] << 16) | (O[2] << 8) | O[3] ))
}

ipv4_format() {
    local N=$1

    printf '%d.%d.%d.%d\n' \
        $(( (N >> 24) & 0xff )) \
        $(( (N >> 16) & 0xff )) \
        $(( (N >> 8) & 0xff )) \
        $(( N & 0xff ))
}

ipv4_apply_mask() {
    local ADDR=$1 BITS=$2
    local MASK=$(( 0xffffffff << (IPV4_BITS - BITS) ))

    echo $(( ADDR & MASK ))
}

# ============================================================================
# IPv6 operations
# ============================================================================

ipv6_expand() {
    local ADDR=$1 MISSING I
    local -a LEFT RIGHT PARTS

    if is_compressed_ipv6 "$ADDR"; then
        IFS=':' read -ra LEFT <<< "${ADDR%%::*}"
        IFS=':' read -ra RIGHT <<< "${ADDR#*::}"
        MISSING=$(( IPV6_GROUPS - ${#LEFT[@]} - ${#RIGHT[@]} ))
        PARTS=("${LEFT[@]}")
        for ((I = 0; I < MISSING; I++)); do
            PARTS+=("0")
        done
        PARTS+=("${RIGHT[@]}")
    else
        IFS=':' read -ra PARTS <<< "$ADDR"
    fi

    for I in "${!PARTS[@]}"; do
        printf '%04x' "0x${PARTS[I]:-0}"
    done
}

ipv6_find_zero_run() {
    local -n PARTS_REF=$1
    local BEST_START=-1 BEST_LEN=0
    local CUR_START=-1 CUR_LEN=0
    local I

    for I in "${!PARTS_REF[@]}"; do
        if [[ ${PARTS_REF[I]} == "0" ]]; then
            [[ $CUR_START -lt 0 ]] && CUR_START=$I
            ((CUR_LEN++))
        else
            if [[ $CUR_LEN -gt $BEST_LEN ]]; then
                BEST_START=$CUR_START
                BEST_LEN=$CUR_LEN
            fi
            CUR_START=-1
            CUR_LEN=0
        fi
    done
    if [[ $CUR_LEN -gt $BEST_LEN ]]; then
        BEST_START=$CUR_START
        BEST_LEN=$CUR_LEN
    fi

    echo "$BEST_START $BEST_LEN"
}

ipv6_compress() {
    local HEX=$1 I OUT=""
    local -a PARTS

    for ((I = 0; I < IPV6_GROUPS; I++)); do
        PARTS[I]=$(printf '%x' "0x${HEX:$((I * BITS_PER_NIBBLE)):$BITS_PER_NIBBLE}")
    done

    local RUN_INFO BEST_START BEST_LEN
    RUN_INFO=$(ipv6_find_zero_run PARTS)
    read -r BEST_START BEST_LEN <<< "$RUN_INFO"

    if ! worth_compressing "$BEST_LEN"; then
        for I in "${!PARTS[@]}"; do
            [[ $I -gt 0 ]] && OUT+=":"
            OUT+="${PARTS[I]}"
        done
    else
        for ((I = 0; I < BEST_START; I++)); do
            [[ $I -gt 0 ]] && OUT+=":"
            OUT+="${PARTS[I]}"
        done
        OUT+="::"
        for ((I = BEST_START + BEST_LEN; I < IPV6_GROUPS; I++)); do
            [[ $I -gt $((BEST_START + BEST_LEN)) ]] && OUT+=":"
            OUT+="${PARTS[I]}"
        done
    fi
    echo "$OUT"
}

ipv6_apply_mask() {
    local HEX=$1 POS=$2
    local CHAR_POS=$((POS / BITS_PER_NIBBLE))
    local BIT_OFF=$((POS % BITS_PER_NIBBLE))
    local RESULT="${HEX:0:$CHAR_POS}"

    if [[ $BIT_OFF -gt 0 ]]; then
        local NIBBLE="${HEX:$CHAR_POS:1}"
        local VAL=$((0x$NIBBLE))
        local MASK=$(( (0xf << (BITS_PER_NIBBLE - BIT_OFF)) & 0xf ))
        RESULT+=$(printf '%x' $((VAL & MASK)))
    fi

    while [[ ${#RESULT} -lt $IPV6_HEX_LEN ]]; do
        RESULT+="0"
    done
    echo "$RESULT"
}

ipv6_add_host() {
    local HEX=$1 HOSTNUM=$2
    local HOSTNUM_HEX RESULT

    HOSTNUM_HEX=$(dc -e "16 o ${HOSTNUM} p")
    RESULT=$(dc -e "16 o 16 i ${HEX^^} ${HOSTNUM_HEX} + p" \
        | tr -d '\\\n' | tr '[:upper:]' '[:lower:]')

    while [[ ${#RESULT} -lt $IPV6_HEX_LEN ]]; do
        RESULT="0$RESULT"
    done
    echo "$RESULT"
}

cidr_host_v4() {
    local PREFIX=$1 HOSTNUM=$2
    local ADDR=${PREFIX%/*}
    local BITS=${PREFIX#*/}
    local HOSTBITS=$((IPV4_BITS - BITS))

    has_host_bits "$HOSTBITS" || die "Error: no host bits available in /$BITS prefix"

    local MAX=$(( (1 << HOSTBITS) - 1 ))

    if is_negative "$HOSTNUM"; then
        HOSTNUM=$(( MAX + 1 + HOSTNUM ))
        is_negative "$HOSTNUM" && die "Error: hostnum $2 underflows for $HOSTBITS host bits"
    fi

    [[ $HOSTNUM -gt $MAX ]] && die "Error: hostnum $HOSTNUM exceeds maximum $MAX for $HOSTBITS host bits"

    local BASE RESULT
    BASE=$(ipv4_parse "$ADDR")
    BASE=$(ipv4_apply_mask "$BASE" "$BITS")
    RESULT=$(( BASE + HOSTNUM ))

    ipv4_format "$RESULT"
}

cidr_host_v6() {
    local PREFIX=$1 HOSTNUM=$2
    local ADDR=${PREFIX%/*}
    local BITS=${PREFIX#*/}
    local HOSTBITS=$((IPV6_BITS - BITS))

    has_host_bits "$HOSTBITS" || die "Error: no host bits available in /$BITS prefix"

    if is_negative "$HOSTNUM"; then
        local DC_HOSTNUM="_${HOSTNUM#-}"
        HOSTNUM=$(dc -e "2 $HOSTBITS ^ $DC_HOSTNUM + p")
        [[ ${HOSTNUM:0:1} == "-" ]] && die "Error: hostnum $2 underflows for $HOSTBITS host bits"
    fi

    if fits_in_bash "$HOSTBITS"; then
        local MAX=$(( (1 << HOSTBITS) - 1 ))
        [[ $HOSTNUM -gt $MAX ]] && die "Error: hostnum $HOSTNUM exceeds maximum $MAX for $HOSTBITS host bits"
    fi

    local HEX
    HEX=$(ipv6_expand "$ADDR")
    HEX=$(ipv6_apply_mask "$HEX" "$BITS")
    HEX=$(ipv6_add_host "$HEX" "$HOSTNUM")

    ipv6_compress "$HEX"
}

# ============================================================================
# Main
# ============================================================================

main() {
    has_arguments "$@" || usage

    local PREFIX=$1 HOSTNUM=$2

    has_cidr_slash "$PREFIX" \
        || die "Error: PREFIX must be in CIDR notation (e.g., 10.0.0.0/24)"
    is_integer "$HOSTNUM" \
        || die "Error: HOSTNUM must be an integer"

    if is_ipv6 "$PREFIX"; then
        cidr_host_v6 "$PREFIX" "$HOSTNUM"
    else
        cidr_host_v4 "$PREFIX" "$HOSTNUM"
    fi
}

main "$@"
